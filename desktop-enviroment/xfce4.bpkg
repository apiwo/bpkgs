#bpkg
name="xfce4"
desc="XFCE lightweight desktop environment."
info="https://xfce.org/"
version="4.18"
license="GPL-2.0"
maintainer="apiwo"
arch="x86_64"
priority="optional"
depends="gtk3-dev, gcc, make, cmake"
build-type="tarball"
download="https://archive.xfce.org/xfce/4.18/src/xfce4-panel-4.18.0.tar.bz2"

build() {
    ./configure --prefix=/usr
    make
}

instructions() {
    DESTDIR="$SCRAP_PKG_DEST" make install
}
