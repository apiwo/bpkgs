#bpkg
name="btop"
desc="Modern resource monitor."
info="https://github.com/aristocratos/btop"
version="1.3.2"
license="Apache-2.0"
maintainer="apiwo"
arch="x86_64"
priority="optional"
depends="gcc, make"
build-type="tarball"
download="https://github.com/aristocratos/btop/archive/refs/tags/v1.3.2.tar.gz"

build() {
    make
}

instructions() {
    DESTDIR="$SCRAP_PKG_DEST" make install PREFIX=/usr
}
