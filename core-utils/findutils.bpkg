#bpkg
name="findutils"
desc="GNU utilities for finding files."
info="https://www.gnu.org/software/findutils/"
version="4.10.0"
license="GPL-3.0"
maintainer="apiwo"
arch="x86_64"
priority="optional"
depends="gcc, make"
build-type="tarball"
download="https://ftp.gnu.org/gnu/findutils/findutils-4.10.0.tar.xz"

build() {
    ./configure --prefix=/usr
    make
}

instructions() {
    DESTDIR="$SCRAP_PKG_DEST" make install
}
