#bpkg
name="tcc"
desc="Tiny C Compiler."
info="https://bellard.org/tcc/"
version="0.9.27"
license="LGPL-2.1"
maintainer="apiwo"
arch="x86_64"
priority="optional"
depends="make, gcc"
build-type="tarball"
download="https://download.savannah.gnu.org/releases/tinycc/tcc-0.9.27.tar.bz2"

build() {
    ./configure --prefix=/usr
    make
}

instructions() {
    DESTDIR="$SCRAP_PKG_DEST" make install
}
